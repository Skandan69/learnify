# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored — never commit real keys.

# Required: your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Stability AI key for Image Story format (get one at platform.stability.ai)
STABILITY_API_KEY=sk-...
